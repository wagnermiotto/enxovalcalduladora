# Copie para .env e preencha. O .env nunca vai para o git.

# --- Desenvolvimento local (SQLite, zero configuração) ---
DATABASE_URL="file:./dev.db"

# --- Produção na Hostinger (MySQL — crie em hPanel > Bancos de dados) ---
# Antes de publicar, rode: npm run db:mysql
# DATABASE_URL="mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO"

# Segredo da sessão de login. Gere um novo com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Senha do primeiro admin criado pelo seed (npx prisma db seed).
# Sem esta variável o seed usa "enxoval123" — troque em produção.
# SEED_ADMIN_SENHA="defina-uma-senha-forte"
# SEED_ADMIN_USUARIO="admin"

# Só para popular tecidos/acessórios de demonstração no primeiro seed:
# SEED_DEMO="1"
