# Copie para .env e preencha. O .env nunca vai para o git.

# ---------------------------------------------------------------------
# BANCO DE DADOS
# ---------------------------------------------------------------------
# O provider do Prisma é ajustado sozinho pelo protocolo desta URL
# (file: = SQLite, postgresql: = Supabase, mysql: = Hostinger).

# Desenvolvimento local, sem configurar nada:
DATABASE_URL="file:./dev.db"

# Produção com Supabase (Project Settings > Database > Connection string):
# Use a porta 5432 (session mode) — o Prisma precisa de conexão direta.
# DATABASE_URL="postgresql://postgres.SEUPROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Produção com MySQL da Hostinger (alternativa ao Supabase):
# DATABASE_URL="mysql://USUARIO:SENHA@srvNNNN.hstgr.io:3306/BANCO"

# ---------------------------------------------------------------------
# SESSÃO
# ---------------------------------------------------------------------
# Gere um novo com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# ---------------------------------------------------------------------
# SUPABASE (opcional — só se for usar storage ou tempo real)
# ---------------------------------------------------------------------
# O acesso aos dados é pelo Prisma; estas duas só fazem falta para recursos
# próprios do Supabase. A publishable key pode ir para o navegador; a chave
# service_role NUNCA deve aparecer aqui nem no código do cliente.
# NEXT_PUBLIC_SUPABASE_URL="https://SEUPROJETO.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ---------------------------------------------------------------------
# SEED (primeiro acesso)
# ---------------------------------------------------------------------
# Senha do admin criado pelo seed. Sem esta variável o seed usa "enxoval123",
# que é pública — DEFINA antes de publicar.
# SEED_ADMIN_SENHA="defina-uma-senha-forte"
# SEED_ADMIN_USUARIO="admin"

# Popula tecidos/acessórios de demonstração (não use em produção):
# SEED_DEMO="1"
